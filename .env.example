# =============================================================================
# ORCradar — modelo de variáveis de ambiente
# =============================================================================
# 1. Copie este arquivo para `.env` na raiz do projeto.
# 2. Preencha com os valores reais do projeto Supabase (o MESMO do ORCtech).
# 3. NUNCA commite o `.env`. Só este `.env.example` fica versionado.
# 4. Variáveis com prefixo `VITE_` são expostas ao navegador. NÃO coloque
#    segredos server-side (service_role) atrás de `VITE_`.
# =============================================================================

# ----- Supabase (público — seguro no bundle do navegador) --------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ----- Metadados do app ------------------------------------------------------
# Ambiente: development | staging | production
VITE_APP_ENV=development
